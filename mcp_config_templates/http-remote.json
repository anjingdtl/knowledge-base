{
  "_说明": "streamable-http 远程接入模板。仅在需要多个 Agent 共享同一个常驻 MCP 服务时使用。",
  "_启动命令_本机": "python run_mcp.py -t streamable-http --host 127.0.0.1 --port 9000",
  "_启动命令_局域网": "python run_mcp.py -t streamable-http --host 0.0.0.0 --port 9000",
  "_接入URL": "http://127.0.0.1:9000/mcp",
  "mcpServers": {
    "shinehe-kb": {
      "type": "http",
      "url": "http://127.0.0.1:9000/mcp"
    }
  }
}
