{
  "_说明": "OpenCode MCP 配置。OpenCode 使用 mcp 字段，不使用 mcpServers。",
  "_配置位置": "~/.config/opencode/opencode.json 或项目根目录 opencode.json",
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shinehe-kb": {
      "type": "local",
      "command": [
        "C:/Users/Administrator/AppData/Local/Programs/Python/Python314/python.exe",
        "D:/ClaudeCodeWorkSpace/projects/knowledge-base/run_mcp.py"
      ],
      "environment": {
        "SHINEHE_HOME": "D:/ClaudeCodeWorkSpace/projects/knowledge-base"
      },
      "enabled": true
    }
  }
}
