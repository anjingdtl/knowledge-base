{
    "_说明": "Roo Code MCP 配置（VS Code 扩展）",
    "_配置文件位置_Windows": "%APPDATA%\\Code\\User\\globalStorage\\rooveterinaryinc.roo-cline\\settings\\cline_mcp_settings.json",
    "_配置文件位置_macOS": "~/Library/Application Support/Code/User/globalStorage/rooveterinaryinc.roo-cline/settings/cline_mcp_settings.json",
    "_Windows注意事项": [
        "1. Windows 上推荐使用 Python 绝对路径，避免 PATH 找不到 python",
        "2. 不要用 cmd /c 包装 Python 命令，会破坏 stdio 协议"
    ],

    "stdio_源码模式_Windows(推荐)": {
        "shinehe-kb": {
            "command": "C:/Users/Administrator/AppData/Local/Programs/Python/Python314/python.exe",
            "args": ["D:/ClaudeCodeWorkSpace/projects/knowledge-base/run_mcp.py"],
            "cwd": "D:/ClaudeCodeWorkSpace/projects/knowledge-base",
            "env": {
                "SHINEHE_HOME": "D:/ClaudeCodeWorkSpace/projects/knowledge-base"
            },
            "disabled": false,
            "alwaysAllow": []
        }
    },

    "stdio_已安装模式": {
        "shinehe-kb": {
            "command": "shinehe-mcp",
            "args": [],
            "env": {
                "SHINEHE_HOME": "你的知识库项目路径"
            },
            "disabled": false,
            "alwaysAllow": []
        }
    }
}
