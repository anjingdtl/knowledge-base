      "typographySystem": "Fraunces serif for all text with ui-serif/serif fallback for CJK (system Song/宋体); sentence case labels; generous tracking 0.01em; spacious headlines",
      "radiusScale": "global --radius 32px; panels and cards use radius*0.82 (~26px); buttons and inputs use radius*0.76 (~24px); nav items use radius*0.72 (~23px); pill badges use 999px",
      "surfaceDepthModel": "flat — shadow opacity is 0 across all tokens; hierarchy comes from warm border --border #e1dccf and surface tone shifts; no drop shadows on static elements",
      "ctaStyle": "primary button: deep cocoa fill + parchment text + 24px radius + min-height 2.95rem; secondary: olive #9b965f fill; ghost: transparent + border; hover lifts 1px",
      "alignmentRules": "grid-based content layout with generous gaps (spacing*3 to spacing*5); topbar actions right-aligned; nav items left-aligned with icon chip + label + meta"
    },
